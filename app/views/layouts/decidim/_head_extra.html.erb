<%
  source = ENV['ANALYTICS_SCRIPT_SOURCE']

  mandant =
    case current_organization.reference_prefix
    when "quartiere" then ENV['ANALYTICS_META_MANDANT_QUARTIERE']
    else                  ENV['ANALYTICS_META_MANDANT']
    end
%>

<% if mandant %>
    <!-- Adobe Analytics Mandant -->
    <meta name="mandant" content="<%=mandant%>">
    <!-- End Adobe Analytics Mandant -->
<% end %>

<% if source %>
  <!-- Adobe Analytics Source -->
  <script src="<%=source%>" async></script>
  <!-- End Adobe Analytics Source -->
<% end %>

<script type="text/javascript">
  let html = document.getElementsByTagName('html')[0]
  html.dataset.railsControllerName = '<%= controller_name %>'
  html.dataset.railsControllerPath = '<%= controller_path %>'
  html.dataset.railsActionName = '<%= action_name %>'
</script>
